# =============================================================================
# NEXUS ALPHA - Environment Configuration Template
# Copy to .env and fill in your values. Never commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# RUNTIME
# ---------------------------------------------------------------------------
ENVIRONMENT=paper          # paper | live
PAPER_MODE=true            # true | false — redundant safety flag
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ---------------------------------------------------------------------------
# BINANCE (Crypto — primary exchange)
# ---------------------------------------------------------------------------
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_key_here
BINANCE_TESTNET=true       # true = use testnet endpoints

# ---------------------------------------------------------------------------
# BYBIT (Crypto — fallback exchange)
# ---------------------------------------------------------------------------
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_SECRET=your_bybit_secret_key_here
BYBIT_TESTNET=true

# ---------------------------------------------------------------------------
# OKX (Crypto — secondary fallback)
# ---------------------------------------------------------------------------
OKX_API_KEY=your_okx_api_key_here
OKX_SECRET=your_okx_secret_key_here
OKX_PASSPHRASE=your_okx_passphrase_here
OKX_SANDBOX=true

# ---------------------------------------------------------------------------
# OANDA (Forex)
# ---------------------------------------------------------------------------
OANDA_ACCOUNT_ID=your_oanda_account_id_here
OANDA_ACCESS_TOKEN=your_oanda_access_token_here
OANDA_PRACTICE=true        # true = practice account, false = live

# ---------------------------------------------------------------------------
# ZERODHA / KITE (Indian Stocks)
# ---------------------------------------------------------------------------
ZERODHA_API_KEY=your_zerodha_api_key_here
ZERODHA_API_SECRET=your_zerodha_api_secret_here
ZERODHA_USER_ID=your_zerodha_user_id_here
ZERODHA_TOTP_SECRET=your_zerodha_totp_base32_secret_here

# ---------------------------------------------------------------------------
# ALPACA (US Stocks)
# ---------------------------------------------------------------------------
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_PAPER=true          # true = paper trading endpoint

# ---------------------------------------------------------------------------
# INTERACTIVE BROKERS
# ---------------------------------------------------------------------------
IBKR_HOST=127.0.0.1
IBKR_PORT=7497             # 7497 = paper, 7496 = live TWS; 4002 = paper IB Gateway
IBKR_CLIENT_ID=1

# ---------------------------------------------------------------------------
# LLM PROVIDERS
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
QWEN_API_KEY=your_qwen_api_key_here

# Ollama (local LLM server)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# LLM cost guardrail — halt AI calls if daily spend exceeds this
MAX_DAILY_LLM_COST_USD=10.00

# ---------------------------------------------------------------------------
# DATABASE — SUPABASE
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ---------------------------------------------------------------------------
# DATABASE — DIRECT POSTGRES (SQLAlchemy async)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres

# ---------------------------------------------------------------------------
# REDIS (caching / pub-sub)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# ALERTS — TELEGRAM
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ---------------------------------------------------------------------------
# ALERTS — DISCORD
# ---------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here

# ---------------------------------------------------------------------------
# DATA FEEDS
# ---------------------------------------------------------------------------
WHALE_ALERT_API_KEY=your_whale_alert_api_key_here

# ---------------------------------------------------------------------------
# VPS / DEPLOYMENT
# ---------------------------------------------------------------------------
VPS_HOST=your.vps.ip.or.hostname
VPS_USER=ubuntu
